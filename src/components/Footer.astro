---
import { AUTHOR } from '../config';

const today = new Date();
const text = 'Minimal. Practical. Worth Sharing.';
---

<footer class="site-footer">
	<p>
		&copy; {today.getFullYear()}
		{AUTHOR.name}. {text}
	</p>
</footer>

<style>
	.site-footer {
		width: var(--site-width);
		padding: 2rem 0;
		text-align: center;
		border-top: 1px solid rgba(218, 234, 255, 0.1);
		margin-top: 4rem;
		margin-left: auto;
		margin-right: auto;
	}

	p {
		color: var(--light);
		font-size: 0.9rem;
		margin: 0;
		opacity: 0.8;
	}
</style>
