---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  const paths = allPosts.flatMap((post) => {
    const tags = post.data.tags || [];
    return tags.map((tag: string) => ({ params: { tag } }));
  });

  const uniqueTags = [...new Set(paths.map((p) => p.params.tag))];

  return uniqueTags.map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const t = useTranslations();

const posts = await getCollection('blog', (post: CollectionEntry<'blog'>) => {
  return (post.data.tags || []).includes(tag);
});

posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageTitle = `Zahit | #${tag}`;
const pageDescription = `All posts tagged with "${tag}"`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<div class="tag-header">
		<a href="/tags/" class="back-link">
			<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
			{t('tags.title')}
		</a>
		<h1>#{tag}</h1>
		<p class="tag-subtitle">{pageDescription}</p>
	</div>

	<section class="posts-list">
		{posts.length > 0 ? (
			<ul>
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>
							<span class="title">{post.data.title}</span>
							<span class="date">
								{post.data.pubDate.toLocaleDateString('en', {
									year: 'numeric',
									month: 'long',
									day: 'numeric',
								})}
							</span>
						</a>
					</li>
				))}
			</ul>
		) : (
			<p class="no-posts">No posts found with this tag.</p>
		)}
	</section>
</BaseLayout>

<style>
	.tag-header {
		margin-bottom: 3rem;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.9rem;
		color: var(--light);
		text-decoration: none;
		margin-bottom: 1.5rem;
		transition: all var(--transition-speed) ease;
	}

	.back-link:hover {
		color: #ffffff;
		transform: translateX(-3px);
	}

	.back-link svg {
		transition: transform var(--transition-speed) ease;
	}

	h1 {
		margin-top: 0;
		margin-bottom: 0.5rem;
	}

	.tag-subtitle {
		font-size: 1.05rem;
		color: rgba(218, 234, 255, 0.6);
		margin: 0;
	}

	ul {
		list-style-type: none;
		padding: 0;
		margin: 0;
	}

	li {
		margin-bottom: 0;
	}

	li a {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		padding: 0.85rem 0;
		border-bottom: 1px solid rgba(218, 234, 255, 0.05);
		transition: all var(--transition-speed) ease;
	}

	li a:hover .title {
		color: var(--text-color);
	}

	li a:hover {
		padding-left: 0.5rem;
	}

	.title {
		font-size: clamp(1rem, 2.5vw, 1.15rem);
		font-weight: 600;
		color: var(--light);
		transition: color var(--transition-speed) ease;
	}

	.date {
		font-size: 0.85rem;
		color: rgba(218, 234, 255, 0.5);
		margin-top: 0.15rem;
	}

	@media (min-width: 640px) {
		li a {
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
		}

		.date {
			margin-top: 0;
			flex-shrink: 0;
			margin-left: 1rem;
		}
	}

	.no-posts {
		color: rgba(218, 234, 255, 0.5);
		font-style: italic;
	}
</style>
