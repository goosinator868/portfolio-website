---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 | Page Not Found" description="Page not found.">
    <div class="not-found">
        <span class="code">404</span>
        <h1>Page not found.</h1>
        <p>
            The page you're looking for may have moved, been deleted, or never existed.
            Sometimes getting lost is where it starts.
        </p>
        <div class="actions">
            <a href="/">Return home</a>
            <a href="/archive/" class="secondary">Browse posts</a>
        </div>
    </div>
</BaseLayout>

<style>
    .not-found {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: center;
        min-height: 60vh;
        gap: 1.5rem;
    }

    .code {
        font-size: clamp(6rem, 15vw, 12rem);
        font-weight: 700;
        line-height: 1;
        color: transparent;
        -webkit-text-stroke: 2px rgba(79, 165, 216, 0.2);
        letter-spacing: -0.05em;
        user-select: none;
    }

    h1 {
        font-size: clamp(1.5rem, 4vw, 2.5rem);
        margin-top: 0;
        color: #ffffff;
    }

    p {
        font-size: 1.1rem;
        color: rgba(218, 234, 255, 0.7);
        max-width: 480px;
        line-height: 1.7;
        margin-bottom: 0;
    }

    .actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 0.5rem;
    }

    .actions a {
        padding: 0.6rem 1.4rem;
        border-radius: 6px;
        font-size: 0.95rem;
        font-weight: 600;
        transition: all var(--transition-speed) ease;
        text-decoration: none;
    }

    .actions a:not(.secondary) {
        background: var(--accent);
        color: #ffffff;
    }

    .actions a:not(.secondary):hover {
        background: var(--light);
        color: var(--bg-color);
    }

    .actions a.secondary {
        color: var(--light);
        border: 1px solid rgba(79, 165, 216, 0.3);
    }

    .actions a.secondary:hover {
        border-color: var(--light);
        color: #ffffff;
    }
</style>
